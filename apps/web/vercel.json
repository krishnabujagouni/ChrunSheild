{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/webhook-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/billing-sweep",
      "schedule": "0 6 1 * *"
    }
  ]
}
