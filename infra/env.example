# Vercel (Next.js) + Railway (agents)  copy to .env locally; never commit secrets.

# Clerk (dashboard auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

ANTHROPIC_API_KEY=
# apps/web cancel-chat (optional override)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Same key as agents  enables pgvector semantic digest retrieval for /api/feedback/search (AI Analyst)
VOYAGE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
# Must match URL registered in Stripe Dashboard → Connect → OAuth redirects
STRIPE_CONNECT_REDIRECT_URI=http://localhost:3000/api/stripe/connect/callback
# Shared secret: required query ?secret= or header x-churnshield-onboard-secret on /api/stripe/connect/start (replace with Clerk session later)
CHURNSHIELD_ONBOARD_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
STRIPE_WEBHOOK_SECRET=
DATABASE_URL=
UPSTASH_REDIS_URL=
RESEND_API_KEY=
OPENAI_API_KEY=
